{
  "name": "Majjiga Pulusu",
  "category": "Curry",
  "area": "Telugu",
  "ingredients": [
    {
      "name": "3 cups sour buttermilk",
      "measure": ""
    },
    {
      "name": "3 tbsp besan (gram flour)",
      "measure": ""
    },
    {
      "name": "1/2 cup grated coconut",
      "measure": ""
    },
    {
      "name": "3 green chillies",
      "measure": ""
    },
    {
      "name": "1 tsp cumin seeds",
      "measure": ""
    },
    {
      "name": "1 tbsp ginger, chopped",
      "measure": ""
    },
    {
      "name": "1/2 tsp turmeric",
      "measure": ""
    },
    {
      "name": "1 tsp mustard seeds",
      "measure": ""
    },
    {
      "name": "2 dried red chillies",
      "measure": ""
    },
    {
      "name": "2 sprigs curry leaves",
      "measure": ""
    },
    {
      "name": "2 tbsp oil",
      "measure": ""
    },
    {
      "name": "salt",
      "measure": ""
    }
  ],
  "steps": [
    "Grind coconut, green chillies, cumin and ginger to a fine paste.",
    "Whisk besan and turmeric into the buttermilk so there are no lumps.",
    "Cook the buttermilk with the ground paste and salt on low heat, stirring, until it thickens gently — never letting it boil over.",
    "Crackle mustard seeds, red chillies and curry leaves in oil.",
    "Pour the tempering on top and serve warm with rice."
  ],
  "tags": "veg,andhra,quick"
}

# Copy to .env (gitignored) for local runs. In GitHub Actions, secrets go
# under Settings -> Secrets, tunables under Settings -> Variables.

# --- Secrets ---
IG_ACCESS_TOKEN=paste-your-long-lived-token-here
# IG_USER_ID=1234567890            # optional, looked up from the token
# KIE_API_KEY=paste-kie-ai-key     # AI video reels (Seedance via Kie.ai)
# SARVAM_API_KEY=paste-sarvam-key  # Telugu voiceover (Sarvam Bulbul v3)

# --- Tunables (all optional; defaults shown) ---
# IG_HANDLE=roadside_mobile        # handle shown in overlays/captions
# REEL_SECONDS=36                  # target reel length (keep under 60)
# SHOT_SECONDS=5                   # length of each AI cut
# REEL_PROBABILITY=0.5             # 0 = always carousel, 1 = always reel
# KIE_RESOLUTION=480p              # 480p or 720p (720p ~2x credits)
# KIE_SEEDANCE_MODEL=bytedance/seedance-2-mini
# SARVAM_SPEAKER=shreya            # bulbul:v3 voice name
# POST_FORMAT=                     # force "reel" or "carousel" for one run

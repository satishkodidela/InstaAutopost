# Copy to .env (gitignored) for local test posting with src/test_post.py
IG_ACCESS_TOKEN=paste-your-long-lived-token-here
# Optional — looked up automatically from the token if omitted
# IG_USER_ID=1234567890

# Optional: AI video reels via Kie.ai (Seedance). Without it, reels fall
# back to the free card-slideshow style.
# KIE_API_KEY=paste-kie-ai-key-here

# Optional: Telugu voiceover via Sarvam AI (Bulbul v3). Without it,
# voiceover falls back to free English edge-tts.
# SARVAM_API_KEY=paste-sarvam-key-here

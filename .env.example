# Copy to .env (gitignored) for local runs. In GitHub Actions, secrets go
# under Settings -> Secrets, tunables under Settings -> Variables.

# --- Secrets ---
IG_ACCESS_TOKEN=paste-your-long-lived-token-here
# IG_USER_ID=1234567890            # optional, looked up from the token
# KIE_API_KEY=paste-kie-ai-key     # AI video reels (Seedance via Kie.ai)
# GEMINI_API_KEY=paste-gemini-key  # AI video reels (Veo 3.1) when VIDEO_BACKEND=veo
# ELEVEN_LABS_API_KEY=paste-key    # Telangana voiceover in a cloned/stock voice (eleven_v3)
# SARVAM_API_KEY=paste-sarvam-key  # Telugu voiceover fallback (Sarvam Bulbul v3)

# --- Tunables (all optional; defaults shown) ---
# IG_HANDLE=roadside_mobile        # handle shown in overlays/captions
# REEL_SECONDS=36                  # target reel length (keep under 60)
# SHOT_SECONDS=5                   # length of each AI cut
# REEL_PROBABILITY=0.5             # 0 = always carousel, 1 = always reel
# VIDEO_BACKEND=seedance           # "seedance" (Kie.ai) or "veo" (Gemini Veo 3.1)
# KIE_RESOLUTION=480p              # 480p or 720p (720p ~2x credits)
# KIE_SEEDANCE_MODEL=bytedance/seedance-2-mini
# REEL_KEYFRAMES=1                 # 0 disables keyframe chaining (single ref image)
# KIE_IMAGE_EDIT_MODEL=google/nano-banana-edit  # boundary keyframe generator
# REEL_STORY=1                     # 0 disables LLM story planning (template beats)
# STORY_MODEL=gemini-flash-latest  # story planner model (needs GEMINI_API_KEY)
# VEO_MODEL=veo-3.1-fast-generate-preview  # or veo-3.1-generate-preview (pricier)
# VEO_PERSON_GENERATION=            # leave unset — Veo picks the right per-mode default
# SARVAM_SPEAKER=shreya            # bulbul:v3 voice name
# ELEVEN_LABS_VOICE_ID=            # stock voice_id now (see: python src/clone_voice.py --list),
#                                  # your cloned voice_id later. Unset => Sarvam voiceover.
# ELEVEN_LABS_MODEL=eleven_v3      # only eleven_v3 speaks Telugu
# REEL_CAPTIONS=1                  # 0 disables burned karaoke captions
# POST_FORMAT=                     # force "reel" or "carousel" for one run
# CHALLENGE=                       # run a themed series (e.g. healthy-7) — set ONLY by the
#                                  # challenge-post workflow; the daily post never sets it.
#                                  # config: recipes/challenges/<slug>.json, state: data/challenge.json
